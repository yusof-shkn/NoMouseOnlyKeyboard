# Supabase Configuration for NDA Medicines Scraper
# Generated: 2025-01-01

# Supabase Project URL
SUPABASE_URL=

# Supabase Anon Key (public key - safe to use)
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# For better performance and avoiding RLS policies, use Service Role Key
# Get it from: Supabase Dashboard > Project Settings > API > service_role key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Your Company ID (must match a company in your companies table)
# To find it, run this SQL query in Supabase:
# SELECT id, company_name FROM companies;
COMPANY_ID=1
